# ---- core ----
DOMAIN=swan.example.com
TZ=Asia/Tehran
ENV=production

# ---- database ----
POSTGRES_USER=swan
POSTGRES_PASSWORD=change_me
POSTGRES_DB=swan
DATABASE_URL=postgresql+asyncpg://swan:change_me@db:5432/swan

# ---- redis ----
REDIS_URL=redis://redis:6379/0

# ---- auth / jwt ----
JWT_SECRET=change_me_access
JWT_REFRESH_SECRET=change_me_refresh
ACCESS_TOKEN_MINUTES=15
REFRESH_TOKEN_DAYS=30

# ---- gemini ----
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ---- google drive (owner personal account, OAuth refresh token) ----
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT=https://swan.example.com/api/v1/files/oauth/callback
GOOGLE_DRIVE_REFRESH_TOKEN=
GOOGLE_DRIVE_ROOT_FOLDER_ID=

# ---- web push (vapid) ----
VAPID_PUBLIC=
VAPID_PRIVATE=
VAPID_SUBJECT=mailto:admin@swan.example.com

# ---- external api / n8n / telegram ----
EXTERNAL_API_MASTER_KEY=change_me_external
N8N_WEBHOOK_URL=

# ---- frontend ----
VITE_API_BASE=/api/v1
